# Core
PORT=5000
MONGO_URI=your-mongodb-connection-string
JWT_SECRET=your-jwt-secret

# Generation LLM (Google Gemini) — used to write the grounded answer.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Retrieval (Voyage AI) — powers real RAG embeddings + reranking.
# Without VOYAGE_API_KEY the document Q&A falls back to keyword search.
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_EMBED_MODEL=voyage-3.5
VOYAGE_RERANK_MODEL=rerank-2.5-lite
# VOYAGE_BASE_URL=https://api.voyageai.com/v1

# RAG tuning (optional)
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_RERANK_CANDIDATES=20
